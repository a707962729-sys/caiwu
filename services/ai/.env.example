# AI 服务配置示例

# 服务端口
PORT=3001

# 环境
NODE_ENV=development

# JWT 配置（与主 API 保持一致）
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# 主 API 地址（用于获取公司数据）
API_BASE_URL=http://localhost:3000/api

# ==================== AI 提供商配置 ====================

# OpenAI 配置
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Claude 配置
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 本地模型配置（Ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ==================== OCR 配置 ====================

# OCR 提供商: openai | baidu | tencent | local
OCR_PROVIDER=openai

# 百度 OCR
BAIDU_OCR_APP_ID=xxx
BAIDU_OCR_API_KEY=xxx
BAIDU_OCR_SECRET_KEY=xxx

# 百度 NLP（用于合同审核增强，需在百度AI平台开通NLP服务）
# 如果不填，将使用 BAIDU_OCR 的密钥（但可能没有NLP权限）
BAIDU_NLP_API_KEY=xxx
BAIDU_NLP_SECRET_KEY=xxx

# 腾讯 OCR
TENCENT_SECRET_ID=xxx
TENCENT_SECRET_KEY=xxx

# ==================== 功能开关 ====================

# 启用 AI 对话
ENABLE_AI_CHAT=true

# 启用 OCR 识别
ENABLE_OCR=true

# 启用审计日志
ENABLE_AUDIT_LOG=true

# ==================== 限制配置 ====================

# 每日调用限制（按用户）
DAILY_LIMIT_USER=100

# 每日调用限制（按公司）
DAILY_LIMIT_COMPANY=1000

# 单次请求最大 Token
MAX_TOKENS_PER_REQUEST=4000

# 请求超时（毫秒）
REQUEST_TIMEOUT=60000

# ==================== 日志配置 ====================

LOG_LEVEL=info